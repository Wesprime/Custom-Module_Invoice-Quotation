<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom print action bound to Sales Orders -->
    <record id="action_report_wesprime_quotation" model="ir.actions.report">
        <field name="name">Wesprime Quotation</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">wesprime_quote_report.report_wesprime_quotation</field>
        <field name="report_file">wesprime_quote_report.report_wesprime_quotation</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="wesprime_quote_report.paperformat_wesprime_quotation"/>
        <field name="print_report_name">'Wesprime Quotation - %s' % (object.name or '')</field>
    </record>
</odoo>

